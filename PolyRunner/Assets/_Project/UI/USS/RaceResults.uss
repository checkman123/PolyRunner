.results-root {
    align-items: center;
    justify-content: center;
    width: 100%; height: 100%;
    background-color: rgba(0,0,0,0.85);
}

.results-list {
    width: 400px;
    margin: 20px 0;
}

.result-row {
    font-size: 22px;
    color: white;
    margin: 6px 0;
    padding: 6px 12px;
    background-color: rgba(255,255,255,0.1);
    border-radius: 4px;
}